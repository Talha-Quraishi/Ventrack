{
  "name": "ventrack",
  "productName": "Ventrack",
  "version": "20.17.4",
  "description": "Offline-first vendor order tracking application (Ventrack).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Talha",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.talha.ventrack.v2",
    "artifactName": "${productName}-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "Talha-Quraishi",
        "repo": "Ventrack"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
